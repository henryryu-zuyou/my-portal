# my-portal 環境變數範本
# ─────────────────────────────────────────────────────────────
# 用法：複製成 .env.local，再填入實際值。
#   cp .env.example .env.local
# 實際值向 Henry 索取，或到 Vercel 專案 Settings → Environment Variables 取得。
# （.env.local 不會進 git，請勿把密鑰貼到這個範本檔）
#
# ⚡ 只想跑「房東租賃所得稅試算」(/rent-tax)？
#    它是純前端頁面，不需要任何環境變數：
#      npm install && npm run dev  →  http://localhost:3000/rent-tax
#    以下變數是其他功能（登入、詢問表單、Ragic 回填）才需要。

# ── 登入保護：首頁 /、/links、/listing 需要 ───────────────────
# Session cookie 的簽章密鑰，自訂一段夠長的隨機字串即可
SESSION_SECRET=
# 可登入的白名單，格式：email:電話,email:電話
ALLOWED_USERS=

# ── 房客詢問表單 /inquiry → Google Chat 通知 ─────────────────
# Google Chat 空間的 incoming webhook 網址
GOOGLE_CHAT_WEBHOOK_URL=

# ── Ragic 資料庫：/listing 回填、部分 /api 需要 ──────────────
# Ragic API key（已是 base64，勿再編碼）
RAGIC_API_KEY=
# 登入 email → Ragic 業務顯示名對應，格式：email:顯示名,email:顯示名
RAGIC_AGENT_MAP=

# ── 舊版入口網站登入（目前程式未使用，可留空）────────────────
ZUYOU_PORTAL_EMAIL=
ZUYOU_PORTAL_PASSWORD=
